# Dependencies
node_modules/

# Your private config — these are generated by `npm run init` from your real data.
# They contain personal info; keep them out of version control.
config/profile.yaml
config/rules.json
config/qa-bank.json
config/queue.yaml
config/companies.json
config/.universe-cursor.json
config/email-imap.json
config/search.json
tracker.csv

# Generated per-user by `npm run init` from CLAUDE.template.md (contains your name/scope)
CLAUDE.md

# Generated application artifacts (resumes, screenshots) — your real submissions
applications/
!applications/.gitkeep

# Browser / automation working dirs (ephemeral, regenerated each run)
.chrome-profile/
.playwright-cli/
.playwright/

# OS / editor cruft
.DS_Store
*.tmp
.~lock.*#

# Python bytecode + tracker backups
__pycache__/
*.pyc
tracker.csv.bak-*
tracker.csv.tmp-*

# Scratch
/tmp/
