# Dependencies
node_modules/

# Your private config — generated/grown by you from your real data.
# They contain personal info; keep them out of version control.
config/profile.yaml
config/rules.json
config/qa-bank.json
config/queue.yaml
config/companies.json
config/companies-universe.json
config/.universe-cursor.json
config/manual-apply.yaml
config/email-imap.json
config/search.json
tracker.csv

# Generated per-user by `npm run init` from CLAUDE.template.md (contains your name/scope)
CLAUDE.md

# Machine-specific Claude Code overrides (the committed .claude/settings.json is shared)
.claude/settings.local.json

# Generated application artifacts (resumes, screenshots) — your real submissions.
# Keep the scaffolding dirs, ignore everything you actually generate inside them.
applications/*
!applications/.gitkeep
!applications/_resumes/
applications/_resumes/*
!applications/_resumes/.gitkeep

# Browser / automation working dirs (ephemeral, regenerated each run)
.auto-apply-chrome*/
.chrome-profile/
.playwright-cli/
.playwright/
playwright-report/
test-results/

# OS / editor cruft
.DS_Store
*.tmp
.~lock.*#

# Python bytecode + tracker backups
__pycache__/
*.pyc
tracker.csv.bak-*
tracker.csv.tmp-*

# Scratch
/tmp/
