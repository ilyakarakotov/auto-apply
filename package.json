{
  "name": "auto-apply-engine",
  "version": "1.0.0",
  "description": "A configurable, open-source job auto-apply pipeline: discover -> plan -> fill -> submit, driven by a single profile.yaml. Built to be driven by Claude Code + Playwright.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "job-application",
    "job-search",
    "ats",
    "greenhouse",
    "lever",
    "ashby",
    "smartrecruiters",
    "workable",
    "automation",
    "claude-code",
    "playwright"
  ],
  "bin": {
    "auto-apply-init": "bin/init.mjs",
    "auto-apply-doctor": "bin/doctor.mjs"
  },
  "scripts": {
    "init": "node bin/init.mjs",
    "doctor": "node bin/doctor.mjs",
    "build-rules": "node src/build-rules.mjs",
    "discover": "node src/discover.mjs > /tmp/cands.json && python3 src/build-queue.py",
    "discover-daily": "bash scripts/discover-daily.sh",
    "sync-jobhive": "node src/sync-jobhive.mjs",
    "jobhive": "python3 src/discover-jobhive.py && CANDS=/tmp/cands-jobhive.json python3 src/build-queue.py",
    "sweep-universe": "bash scripts/sweep-universe.sh",
    "harvest": "node src/harvest-tokens.mjs",
    "plan": "node src/plan-apply.mjs",
    "filler": "node src/make-filler.mjs",
    "pdf": "node src/html-to-pdf.mjs",
    "next": "node src/next-jobs.mjs",
    "followups": "python3 src/scan-followups.py",
    "browser": "bash scripts/start-chrome.sh",
    "browser:vps": "bash scripts/vps-up.sh",
    "worker:browser": "bash scripts/worker-browser.sh",
    "orchestrate": "bash scripts/daily-orchestrate.sh",
    "batch": "bash scripts/batch-loop.sh",
    "nightly": "bash scripts/run-nightly.sh",
    "test": "node --test test/*.test.mjs",
    "test:followups": "python3 test/test-scan-followups.py"
  },
  "dependencies": {
    "imapflow": "^1.4.0",
    "playwright": "^1.50.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.14"
  },
  "engines": {
    "node": ">=18"
  }
}
